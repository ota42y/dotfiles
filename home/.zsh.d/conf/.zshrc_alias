alias rm='rm -i'
alias k='kubectl'

alias g='git'
alias gci='g ci'
alias gpo='g po'
alias gst='g st'
alias gftp='g ftp'

alias t='tig'
alias ta='tig --all'

alias gcd='cd $(ghq root)/$(ghq list | peco)'
alias gb='open https://$(ghq list | peco | cut -d "/" -f 1-3)'

vscode_remote() {
  local socket rc_code
  socket="$(ls -1t /run/user/$UID/vscode-ipc-*.sock 2>/dev/null | head -n1 || true)"

  stable_dir="$(ls -1dt /home/ota42y/.vscode-server/cli/servers/Stable* 2>/dev/null \
  | grep -v '\.staging$' \
  | head -n1 || true)"

  rc_code="${stable_dir}/server/bin/remote-cli/code"

  VSCODE_IPC_HOOK_CLI="$socket" "$rc_code" "$@"
}

alias co=vscode_remote
